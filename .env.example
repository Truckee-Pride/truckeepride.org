# Truckee Pride — Environment Variables
# Copy to .env.local and fill in values.

# --- Required from Phase 0 ---
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Public-facing app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Required from Phase 3 (Auth & Email) ---
# Auth.js secret: generate with `openssl rand -base64 32`
AUTH_SECRET=
# Auth.js canonical URL
AUTH_URL=http://localhost:3000
# Resend API key for magic link emails
RESEND_API_KEY=
# From address for auth emails
EMAIL_FROM=Truckee Pride <auth@truckeepride.org>

# --- Required from Phase 4 (Image Uploads) ---
# Vercel Blob read/write token
BLOB_READ_WRITE_TOKEN=

# --- Required for Places Autocomplete ---
# Google Maps API key (server-side only — restricted by API)
GOOGLE_PLACES_API_KEY=
# Upstash Redis (from upstash.com console — use the REST URL, not redis://)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
